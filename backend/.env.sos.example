# Twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio sender numbers (E.164 format, e.g. +27123456789)
TWILIO_WHATSAPP_FROM=
TWILIO_VOICE_FROM=

# Comma-separated recipient numbers in E.164 format
SOS_ALERT_NUMBERS=

# Channel toggles (optional)
SOS_WHATSAPP_ENABLED=true
SOS_VOICE_ENABLED=true
